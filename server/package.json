{
  "name": "couponsfeast-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "cypress run",
    "test:open": "cypress open",
    "test:backend": "cypress run --spec 'cypress/e2e/backend-apis/**/*.cy.js'",
    "test:frontend": "cypress run --spec 'cypress/e2e/frontend-apis/**/*.cy.js'",
    "test:admin": "cypress run --spec 'cypress/e2e/backend-apis/admin-apis/**/*.cy.js'",
    "test:stores": "cypress run --spec 'cypress/e2e/backend-apis/store-apis/**/*.cy.js'",
    "test:coupons": "cypress run --spec 'cypress/e2e/backend-apis/coupon-*/**/*.cy.js'",
    "test:analytics": "cypress run --spec 'cypress/e2e/backend-apis/analytics-apis/**/*.cy.js'",
    "test:homepage": "cypress run --spec 'cypress/e2e/frontend-apis/homepage-apis/**/*.cy.js'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "cypress": "^15.11.0",
    "nodemon": "^3.0.2"
  }
}
