{
  "name": "couponsfeast-api-tests",
  "version": "1.0.0",
  "description": "Cypress API tests for CouponsFeast platform",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    
    "test:api": "cypress run --spec 'cypress/e2e/**/*.cy.js'",
    "test:api:headless": "cypress run --headless --spec 'cypress/e2e/**/*.cy.js'",
    
    "test:public": "cypress run --spec 'cypress/e2e/public/*.cy.js'",
    "test:admin": "cypress run --spec 'cypress/e2e/admin/*.cy.js'",
    "test:backend": "cypress run --spec 'cypress/e2e/backend/*.cy.js'",
    "test:legacy": "cypress run --spec 'cypress/e2e/legacy/*.cy.js'",
    
    "test:public:open": "cypress open --spec 'cypress/e2e/public/*.cy.js'",
    "test:admin:open": "cypress open --spec 'cypress/e2e/admin/*.cy.js'",
    "test:backend:open": "cypress open --spec 'cypress/e2e/backend/*.cy.js'",
    "test:legacy:open": "cypress open --spec 'cypress/e2e/legacy/*.cy.js'",
    
    "test:dev": "cypress run --env ENVIRONMENT=development",
    "test:staging": "cypress run --env ENVIRONMENT=staging",
    "test:prod": "cypress run --env ENVIRONMENT=production",
    
    "test:smoke": "cypress run --spec 'cypress/e2e/public/public-apis.cy.js' --grep 'should get all active'",
    "test:critical": "cypress run --grep 'CRITICAL|should get all|should create|should reveal'",
    
    "test:parallel": "cypress run --record --parallel",
    "test:record": "cypress run --record",
    
    "test:report": "cypress run --reporter mochawesome --reporter-options reportDir=cypress/reports,overwrite=false,html=false,json=true",
    "test:report:merge": "mochawesome-merge cypress/reports/*.json > cypress/reports/merged-report.json",
    "test:report:generate": "marge cypress/reports/merged-report.json --reportDir cypress/reports --inline",
    
    "test:ci": "npm run test:api:headless && npm run test:report && npm run test:report:merge && npm run test:report:generate"
  },
  "devDependencies": {
    "cypress": "^13.0.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  },
  "cypress-cucumber-preprocessor": {
    "nonGlobalStepDefinitions": true,
    "stepDefinitions": "cypress/integration"
  }
}